# =============================================================================
# Shreeji I-Tech Launchpad - Environment Variables
# Copy this file to .env and update values for your environment
# =============================================================================

# Application
NODE_ENV=development

# Frontend (apps/web)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Backend (apps/api)
API_PORT=4000
API_URL=http://localhost:4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://launchpad:launchpad_secret@localhost:5432/launchpad?schema=public
POSTGRES_USER=launchpad
POSTGRES_PASSWORD=launchpad_secret
POSTGRES_DB=launchpad
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT (Admin Authentication - configured for future phases)
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d

# File Uploads (configured for future phases)
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads
